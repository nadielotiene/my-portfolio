---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import ProjectCard from "../components/ProjectCard.astro";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";
---

<Layout title="Kenneth Velázquez - Developer">
  <div class="hero-band">
    <div class="inner">
      <Nav />
      <section class="hero">
        <span class="tag">Full-stack developer</span>
        <h1>Building things<br />for the <em>web.</em></h1>
        <p>
          I create clean, performant web apps - from polished UIs to full-stack
          products.
        </p>
        <div class="actions">
          <a href="#work" class="btn-primary">View projects</a>
          <a href="mailto:kenny.arcelay@gmail.com" class="btn-secondary"
            >Get in touch</a
          >
        </div>
      </section>
    </div>
  </div>

  <main class="inner">
    <section id="work">
      <div class="section-header">
        <span class="label">// Selected work</span>
        <span class="count">04 projects</span>
      </div>
      <div class="grid">
        {projects.map((p) => <ProjectCard {...p} />)}
      </div>
    </section>

    <About />
    <Footer />
  </main>
</Layout>

<style>
  .hero-band {
    background: var(--gradient-sky);
    /* padding-bottom: 4rem; */
  }
  .inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  main.inner {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .hero {
    margin-bottom: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-bg-card);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    line-height: 1.08;
    letter-spacing: -1.5px;
    color: #fff;
    margin-bottom: 1.25rem;
  }

  h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero p {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-bg);
    max-width: 420px;
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-primary,
  .btn-secondary {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.03em;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    opacity: 0.8;
  }

  .btn-secondary {
    border: 0.5px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-secondary:hover {
    opacity: 0.6;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faint);
  }

  .count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-faint);
    /* opacity: 0.6; */
  }

  .grid {
    display: grid;
    /* grid-template-columns: repeat(2, 1fr); */
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 36px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
