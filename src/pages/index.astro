---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import ProjectCard from "../components/ProjectCard.astro";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="Kenneth Velázquez - Developer">
  <main>
    <Nav />

    <section class="hero">
      <div>
        <span class="tag">Full-stack developer</span>
        <h1>Building things<br />for the <em>web.</em></h1>
        <p>
          I create clean, performant web apps - from polished UIs to full-stack
          products.
        </p>
        <div class="actions">
          <a href="#work" class="btn-primary">View projects</a>
          <a href="mailto:kenny.arcelay@gmail.com" class="btn-secondary"
            >Get in touch</a
          >
        </div>
      </div>
    </section>

    <section id="work">
      <div class="section-header">
        <span class="label">Selected work</span>
        <span class="count">04 projects</span>
      </div>
      <div class="grid">
        {projects.map((p) => <ProjectCard {...p} />)}
      </div>
    </section>

    <About />
    <Footer />
  </main>
</Layout>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .hero {
    margin-bottom: 4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 52px;
    line-height: 1.08;
    letter-spacing: -1.5px;
    margin-bottom: 1.25rem;
  }

  .hero p {
    font-size: 15px;
    font-weight: 300;
    color: var(--color-muted);
    max-width: 420px;
    margin-bottom: 1.5rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-primary,
  .btn-secondary {
    font-family: var(--font-serif);
    font-size: 12px;
    font-weight: 500;
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.03em;
  }

  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn-secondary {
    border: 0.5px solid var(--color-border);
    color: var(--color-text);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .label {
    font-family: var(--font-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faint);
  }

  .count {
    font-family: var(--font-serif);
    font-size: 11px;
    color: #bbb;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 36px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
