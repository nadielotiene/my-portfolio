---
const skills = [
  { category: "Frontend", items: ["React", "HTML/CSS", "JavaScript", "Astro"] },
  { category: "Backend", items: ["Express", "Node,js", "SQL"] },
  { category: "Tools", items: ["Git", "Github", "Render", "Vercel"] },
];
---

<section id="about">
  <div class="about-grid">
    <div class="bio">
      <span class="label">About</span>
      <h2>A bit about me.</h2>
      <p>
        I'm a full-stack developer who builds clean, performant web apps - from
        polished React UI's to backend API's with real users. I care about good
        code, good UX, and shipping things that work.
      </p>
      <p>
        Currently open to new opportunities. Based in Puerto Rico, working
        remotely.
      </p>
    </div>

    <div class="skills">
      <span class="label">Skills</span>
      {
        skills.map((group) => (
          <div class="skill-group">
            <span class="category">{group.category}</span>
            <div class="tags">
              {group.items.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--color-border);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-faint);
    display: block;
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 28px;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  p {
    font-size: 14px;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .skill-group {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.75rem;
    align-items: start;
    padding: 0.6rem 0;
    border-bottom: 0.5px solid var(--color-border);
  }

  .skill-group-child {
    border-bottom: none;
  }

  .category {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-faint);
    padding-top: 3px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    border: 0.5px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-muted);
  }

  @media (max-width: 600px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
