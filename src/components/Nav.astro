---
const links = [
  { label: "work", href: "#work" },
  { label: "about", href: "#about" },
  { label: "contact", href: "#contact" },
];
---

<nav>
  <a href="/" class="logo">Kenneth Velázquez</a>
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 0.5px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 20px;
    color: #fff;
  }

  ul {
    display: flex;
    gap: 2rem;
    margin-left: 1rem;
    list-style: none;
  }

  ul a {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.15s;
  }

  ul a:hover {
    color: #fff;
  }
</style>
